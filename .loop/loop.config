# Per-repo settings for the loop multi-agent dev-loop framework.
#
# Created by `st init`. Edit values to match this repo's conventions.
# This file is shell-sourced and substituted into prompt templates at
# invocation time. Keep values flat (KEY="value"); no arrays, no nesting.

# ---------------------------------------------------------------------------
# Repository identity — REQUIRED, edit before first run
# ---------------------------------------------------------------------------
REPO_OWNER="aniryou"
REPO_NAME="loop-control-tower"
REPO_SLUG="${REPO_OWNER}/${REPO_NAME}"
DEFAULT_BRANCH="main"

# ---------------------------------------------------------------------------
# Branch & worktree conventions
# ---------------------------------------------------------------------------
# All agent-authored PR branches start with this prefix. Used to filter
# eligible PRs in the reviewer orchestrator and the dispatcher loops.
BRANCH_PREFIX="dev-agent"

# Per-issue worktrees live under WORKTREE_BASE. Must NOT be inside the repo,
# and must be UNIQUE per onboarded repo on this machine — two repos sharing
# a base would collide on issue/PR numbers (e.g. issue #5 in repo A vs. #5
# in repo B). The default below interpolates ${REPO_OWNER}/${REPO_NAME} so
# `st init` defaults are already collision-free; override it only if you
# deliberately want a shared base, and then take care to keep distinct
# LOCK_NAME_PREFIX values below as defence-in-depth.
WORKTREE_BASE="/tmp/dev-agent/${REPO_OWNER}-${REPO_NAME}"
LOCK_DIR="${WORKTREE_BASE}/locks"
DISPATCH_LOCK_DIR="${WORKTREE_BASE}/dispatched"

# Defence-in-depth prefix for lock filenames inside LOCK_DIR and
# DISPATCH_LOCK_DIR. Even when WORKTREE_BASE is misconfigured to a path
# already used by another repo, locks stay disambiguated per repo because
# this prefix appears in every claim/dispatch lock filename. Default
# derivation strips `.` (GitHub permits dots in repo names) so a repo
# called `lodash.debounce` produces a clean `lodash-debounce-` prefix.
LOCK_NAME_PREFIX="${REPO_NAME//./-}-"

# ---------------------------------------------------------------------------
# Label scheme
# ---------------------------------------------------------------------------
SEVERITY_LABEL_HIGH="severity:high"
SEVERITY_LABEL_MEDIUM="severity:medium"
SEVERITY_LABEL_LOW="severity:low"
TYPE_LABELS="bug,enhancement,testing,documentation"

# Opt-in label letting a human flag a specific issue for the dev-agent
# regardless of severity. Issues carrying this label are unioned with the
# severity:high / severity:medium queries inside `eligibility_dev_count` and
# `eligibility_dev_candidates`, so a `severity:low` (or no-severity) issue
# can be picked up without inflating its severity. Decouples severity ("how
# bad is this") from queue eligibility ("should the dev-agent work on this").
# Mirrors the BLOCKED_HUMAN_LABEL pattern below in the positive direction —
# that one excludes regardless of severity, this one includes. (GH#148)
AGENT_PICKUP_LABEL="agent-ready"

# Applied by the dev-agent's safety-net flow to issues that need human action
# before any further automated work (e.g. CI-affecting changes, > 200 LOC
# deletions, missing external services). Issues carrying this label are
# excluded from `eligibility_dev_count`, so the wrapper stops re-spawning the
# LLM on each poll cycle. Remove the label manually to re-make an issue
# eligible.
BLOCKED_HUMAN_LABEL="blocked:human"

# ---------------------------------------------------------------------------
# Triage rules (Mode 3 conflict resolution)
# ---------------------------------------------------------------------------
# Files that MUST never be auto-resolved. Add anything where a mechanical
# merge could mask a real semantic conflict — core code paths, Dockerfile,
# CI config, lockfiles, etc.
TRIAGE_CORE_FILES_REGEX='^(Dockerfile|\.pre-commit-config\.yaml)$'
TRIAGE_TESTS_REGEX='(^|/)tests?/|(^|/)test_.*\.py$|_test\.py$'
TRIAGE_CI_SECRETS_REGEX='\.github/|secrets|credentials|\.env'

# Counts ALL lines inside conflict regions across all conflicted files,
# including BOTH the "ours" and "theirs" sides of every <<<<<<< / >>>>>>>
# block. A symmetric 5-line-vs-5-line conflict counts as 10. The default
# is conservative by design — loop's auto-resolve path is a mechanical-
# rebase rescue, not a semantic merge solver.
TRIAGE_LINE_LIMIT=100

# ---------------------------------------------------------------------------
# Loop / dispatch defaults (loop)
# ---------------------------------------------------------------------------
DEV_INSTANCES_DEFAULT=3       # parallel dev-agent workers; capacity governor
POLL_INTERVAL_DEFAULT=60      # seconds between scan cycles

# Cap for exponential backoff on consecutive empty cycles (no eligible work).
# Sleep grows POLL_INTERVAL * 2^streak, clamped here. Resets to POLL_INTERVAL
# on the first non-empty cycle.
EMPTY_CYCLE_BACKOFF_CAP_SECONDS=300

# Maximum number of background dev-agent runs the follow-up + conflicts
# dispatchers may have in flight simultaneously, counted across BOTH
# dispatchers (they share DISPATCH_LOCK_DIR). When at cap, the dispatcher
# logs "at cap (N/N)" and skips remaining eligible PRs this cycle; they
# re-enter the queue next cycle. Independent of DEV_INSTANCES_DEFAULT,
# which controls the foreground tmux-pane workers.
DISPATCH_MAX_CONCURRENT=3

# Reviewer dispatcher cap (GH#117). Maximum number of background
# `run-reviewer.sh <PR>` runs the reviewer dispatcher may fire in parallel.
# Counted INDEPENDENTLY of DISPATCH_MAX_CONCURRENT (review locks live in the
# same DISPATCH_LOCK_DIR but are distinguished by the `*-review.lock` suffix).
# Keeping the cap separate stops a saturated follow-up workload from starving
# new reviews and vice versa. Set to 1 to serialize reviews back to the
# pre-#117 single-pane behavior.
REVIEWER_DISPATCH_MAX_CONCURRENT=3

# ---------------------------------------------------------------------------
# Merger dispatcher (opt-in; activated via `st loop start --enable-merger`)
# ---------------------------------------------------------------------------
# Verdict whitelist: which reviewer-agent verdicts trigger an auto-merge.
# Space-separated. Allowed tokens: clean | nits | comment | changes | blocked.
# Default ("clean nits") matches the loop's actual review pattern: PRs that
# earned a clean or nits-only verdict have no actionable findings, so the
# merger can ship them without further human input. Tighten to "clean" if a
# repo wants every nits-only PR to wait for human eyes.
MERGER_VERDICTS_ALLOWED="clean nits"

# Merge method passed as `--<method>` to `gh pr merge`. Allowed values:
#   squash | merge | rebase
# Squash is the default — the loop produces small, single-purpose PRs and a
# squash keeps main's history flat.
MERGER_MERGE_METHOD="squash"

# 1 = pass `--delete-branch` to `gh pr merge` (cleans up the agent branch
# on origin once the PR lands). 0 = leave the branch (useful for repos that
# retain branches for archival or compliance reasons).
MERGER_DELETE_BRANCH=1

# ---------------------------------------------------------------------------
# Per-mode caps
# ---------------------------------------------------------------------------
DEV_MAX_TURNS=200
REVIEWER_MAX_TURNS=120
DEV_CI_RETRY_ATTEMPTS=5
DEV_FOLLOWUP_CYCLE_LIMIT=3
REVIEWER_BASH_CALL_GUIDANCE=25
STALE_LOCK_HOURS=6

# Consecutive Mode 1 hard-failures (LLM exit non-zero before reaching the
# in-prompt safety-net check) on the same issue before the wrapper escalates
# by adding ${BLOCKED_HUMAN_LABEL} and posting an escalation comment naming
# the wrapper log path. The wrapper tracks the streak via dev-failed:N
# labels on the GH issue itself; a successful run clears them. Default 3 —
# tighten to 2 if you want faster human escalation, loosen to 5+ for repos
# where transient gh / claude API blips are common. (GH#56)
DEV_HARD_FAILURE_RETRY_LIMIT=3

# Consecutive Mode 2 (follow-up) hard-failures on the same PR before the
# wrapper stops posting "🤖 Developer agent — follow-up failed mid-flow"
# stub comments and escalates to a human via ${BLOCKED_HUMAN_LABEL} + one
# explanation comment. Counted by substring-matching the stub marker in
# existing PR comments; eligibility_followup_pr drops PRs carrying the
# label so the dispatcher stops re-firing. Default 3 — tighten to 2 for
# faster escalation, loosen for repos where transient claude/gh blips are
# more common than deterministic failures. (GH#111)
DEV_FOLLOWUP_FAILURE_RETRY_LIMIT=3

# Consecutive Mode 3 (resolve-conflicts) hard-failures on the same PR
# before the wrapper stops posting "🤖 Mode 3 conflict resolution —
# aborted" stub comments and escalates via ${BLOCKED_HUMAN_LABEL} + one
# explanation comment. Counted by the same substring used in both LLM
# graceful-abort comments and the wrapper's hard-fail stub. The conflicts
# dispatcher's predicate (_dispatch_conflicts_jq) drops PRs carrying the
# label so it stops re-firing. The per-trigger drafting (gh pr ready --undo)
# still happens at every hard-failure regardless of the cap — that's the
# per-trigger circuit breaker, not the per-PR cap. Default 3. (GH#111)
DEV_CONFLICTS_FAILURE_RETRY_LIMIT=3

# Consecutive reviewer sub-agent failures on the same PR before the wrapper
# stops posting [reviewer-agent: blocked] stub reviews and escalates to a
# human via ${REVIEWER_ESCALATION_LABEL} + a one-time explanation comment.
# GH#55 closed the per-SHA loop (each new commit is a fresh head), but on
# deterministically-failing PRs (oversized diff, malformed PR) every push
# reproduces the failure and accumulates stubs indefinitely; this cap closes
# the per-PR loop too. Default 3 — tighten to 2 for faster human escalation,
# loosen to 5+ on repos where the sub-agent's failure modes are typically
# transient. (GH#94)
REVIEWER_SUB_AGENT_FAILURE_CAP=3

# Label applied to a PR after REVIEWER_SUB_AGENT_FAILURE_CAP consecutive
# stub-blocked reviews. While present, eligibility_review_pending excludes
# the PR from review dispatch — the wrapper will not re-fire the orchestrator
# until a human removes the label. Mirrors the BLOCKED_HUMAN_LABEL precedent
# used by the dev-agent flow. The label is created on demand (idempotent).
# (GH#94)
REVIEWER_ESCALATION_LABEL="reviewer:needs-human"

# ---------------------------------------------------------------------------
# Project-specific test command (used in Mode 3 post-rebase verification)
# ---------------------------------------------------------------------------
TEST_CMD="pytest -q"

# ---------------------------------------------------------------------------
# Agent markers — change with care; downstream parsers match these literally
# ---------------------------------------------------------------------------
DEV_AGENT_COMMENT_PREFIX="🤖 Developer agent"
DEV_AGENT_PR_BODY_TAG="🤖 Generated by developer agent"
REVIEWER_AGENT_COMMENT_PREFIX="🤖 Reviewer agent"
REVIEWER_AGENT_VERDICT_REGEX='\[reviewer-agent: (clean|nits|comment|changes|blocked)\]'
